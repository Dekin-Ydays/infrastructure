region         = "eu-west-3"
aws_profile    = "default"
project        = "dekin"
instance_type  = "t3.medium"

# Paste the contents of your ~/.ssh/id_ed25519.pub (or similar) here.
ssh_public_key = "ssh-ed25519 AAAA... you@host"

# Lock SSH down to your IP, e.g. "203.0.113.42/32".
ssh_allowed_cidr = "0.0.0.0/0"
